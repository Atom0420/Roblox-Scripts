local refreshQueued = false
local pendingForceRender = false
local lastScanAt = 0

scheduleScan = function(reason, delayTime, forceRender)
	pendingForceRender = pendingForceRender or (forceRender == true)
	if refreshQueued then return end
	refreshQueued = true

	local now = os.clock()
	local requestedDelay = delayTime or 0.25
	local throttleDelay = math.max(0, MIN_SCAN_GAP - (now - lastScanAt))
	local finalDelay = math.max(requestedDelay, throttleDelay)

	task.delay(finalDelay, function()
		refreshQueued = false
		lastScanAt = os.clock()

		local renderNow = pendingForceRender
		pendingForceRender = false

		local ok, err = pcall(function()
			debugDumpSpinPads(false, renderNow)
		end)
		if not ok then
			warn("[TinySpinGUI Live Scan Error]:", reason or "?", err)
		end
	end)
end

local plotConnections = {}
local unlockConnections = {}
local watchedPlot = nil
local watchedTextObjects = {}

local function disconnectLiveWatch()
	for _, conn in ipairs(plotConnections) do
		pcall(function() conn:Disconnect() end)
	end
	for i = #plotConnections, 1, -1 do
		plotConnections[i] = nil
	end
	watchedTextObjects = {}
	watchedPlot = nil
	clearTextCache()
end

local function watchTextObject(obj)
	if not obj or watchedTextObjects[obj] or not isTextObject(obj) then return end
	watchedTextObjects[obj] = true
	addCachedTextObject(obj)

	local ok, conn = pcall(function()
		return obj:GetPropertyChangedSignal("Text"):Connect(function()
			scheduleScan("TextChanged", 0.35, false)
		end)
	end)

	if ok and conn then
		table.insert(plotConnections, conn)
	end
end

local function setupLiveWatch()
	local _, plot = getSortedSpinPads()
	if plot == watchedPlot then return end

	disconnectLiveWatch()
	watchedPlot = plot
	if not plot then return end

	for _, obj in ipairs(plot:GetDescendants()) do
		if isTextObject(obj) then
			watchTextObject(obj)
		end
	end

	table.insert(plotConnections, plot.DescendantAdded:Connect(function(obj)
		textCacheDirty = true
		if isTextObject(obj) then
			watchTextObject(obj)
		end
		scheduleScan("DescendantAdded", 0.45, true)
	end))

	table.insert(plotConnections, plot.DescendantRemoving:Connect(function()
		textCacheDirty = true
		scheduleScan("DescendantRemoving", 0.45, true)
	end))

	local spinPads = plot:FindFirstChild("SpinPads")
	if spinPads then
		table.insert(plotConnections, spinPads.ChildAdded:Connect(function()
			textCacheDirty = true
			scheduleScan("PadAdded", 0.55, true)
		end))
		table.insert(plotConnections, spinPads.ChildRemoved:Connect(function()
			textCacheDirty = true
			scheduleScan("PadRemoved", 0.55, true)
		end))
	end
end

local function watchUnlockValues()
	local function maybeWatch(obj)
		if not obj then return end
		if (obj:IsA("IntValue") or obj:IsA("NumberValue")) and obj.Name:lower():find("spin", 1, true) and obj.Name:lower():find("pad", 1, true) then
			table.insert(unlockConnections, obj.Changed:Connect(function()
				scheduleScan("UnlockValueChanged", 0.1, true)
			end))
		end
	end

	for _, child in ipairs(player:GetChildren()) do
		maybeWatch(child)
	end

	table.insert(unlockConnections, player.ChildAdded:Connect(function(child)
		maybeWatch(child)
		scheduleScan("PlayerChildAdded", 0.1, true)
	end))
end

