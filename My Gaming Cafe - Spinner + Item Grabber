local function parseChance(text)
	if not text then return nil end
	local a, b = tostring(text):lower():match("(%d+)%s*in%s*([%d,]+)")
	if a and b then
		return tostring(a) .. " in " .. tostring(b):gsub(",", "")
	end
	return nil
end

local function parseCashValue(text)
	if not text then return nil end
	local raw = tostring(text)
	local amount = raw:match("%+%s*%$?%s*([%d%.%,]+%s*[KkMmBbTt]?)")
		or raw:match("%$%s*([%d%.%,]+%s*[KkMmBbTt]?)")
	if amount then return parseValue(amount) end
	return nil
end

local function cleanText(s)
	if not s then return "" end
	return tostring(s):gsub("^%s+", ""):gsub("%s+$", "")
end

local function cleanItemName(text)
	local cleaned = cleanText(text)
	if cleaned == "" then return nil end
	local lower = cleaned:lower()

	if BAD_NAME_WORDS[lower] then return nil end
	if RARITY_WORDS[lower] then return nil end
	if parseChance(cleaned) then return nil end
	if parseCashValue(cleaned) then return nil end
	if lower:find("upgrade", 1, true) then return nil end
	if lower:find("works offline", 1, true) then return nil end
	if lower:find("next event", 1, true) then return nil end
	if lower:find("cash", 1, true) then return nil end
	if lower:find("luck", 1, true) then return nil end
	if lower:find("multiplier", 1, true) then return nil end
	if lower:find("pad", 1, true) then return nil end
	if lower:find("plot", 1, true) then return nil end
	if lower:find("common", 1, true) then return nil end
	if #cleaned > 55 then return nil end
	return cleaned
end

local function instancePath(obj)
	local ok, result = pcall(function() return obj:GetFullName() end)
	return ok and result or tostring(obj)
end

local function isTextObject(obj)
	return obj:IsA("TextLabel") or obj:IsA("TextButton") or obj:IsA("TextBox")
end

local function getTextObjectWorldPosition(obj)
	local current = obj
	while current do
		if current:IsA("BillboardGui") or current:IsA("SurfaceGui") then
			local adornee = current.Adornee
			if adornee and adornee:IsA("BasePart") then return adornee.Position end
			if current.Parent and current.Parent:IsA("BasePart") then return current.Parent.Position end
		end
		if current:IsA("BasePart") then return current.Position end
		current = current.Parent
	end
	return nil
end

local function getPartPosition(root)
	if not root then return nil end
	if root:IsA("BasePart") then return root.Position end
	if root:IsA("Model") then
		local ok, cf = pcall(function() return root:GetPivot() end)
		if ok and cf then return cf.Position end
	end
	for _, obj in ipairs(root:GetDescendants()) do
		if obj:IsA("BasePart") then return obj.Position end
	end
	return nil
end

local cachedLocalPlot = nil

local function getLocalPlot()
	if cachedLocalPlot and cachedLocalPlot.Parent then
		return cachedLocalPlot
	end

	local main = workspace:FindFirstChild("Main")
	local plots = main and main:FindFirstChild("Plots")
	if not plots then return nil end

	for _, plot in ipairs(plots:GetChildren()) do
		for _, obj in ipairs(plot:GetDescendants()) do
			if obj:IsA("StringValue") or obj:IsA("ObjectValue") then
				local ok, val = pcall(function() return obj.Value end)
				if ok then
					if val == player or tostring(val) == player.Name or tostring(val) == player.DisplayName then
						cachedLocalPlot = plot
						return cachedLocalPlot
					end
				end
			elseif isTextObject(obj) then
				local text = obj.Text or ""
				if text:lower():find(player.Name:lower(), 1, true) or text:lower():find(player.DisplayName:lower(), 1, true) then
					cachedLocalPlot = plot
					return cachedLocalPlot
				end
			end
		end
	end

	cachedLocalPlot = plots:FindFirstChild("Plot1") or plots:FindFirstChildWhichIsA("Model") or plots:FindFirstChildWhichIsA("Folder")
	return cachedLocalPlot
end

local function getUnlockedPadCount()
	local v = player:FindFirstChild("SpinPadsUnlocked")
	if v and (v:IsA("IntValue") or v:IsA("NumberValue")) then
		local n = tonumber(v.Value)
		if n and n > 0 then return math.floor(n) end
	end

	
	local plot = getLocalPlot()
	local spinPads = plot and plot:FindFirstChild("SpinPads")
	if not spinPads then return math.huge end

	local count = 0
	for _, pad in ipairs(spinPads:GetChildren()) do
		local pos = getPartPosition(pad)
		if pos then count += 1 end
	end
	return count > 0 and count or math.huge
end

local function extractPadNumber(name)
	local n = tostring(name):match("(%d+)")
	return tonumber(n)
end

local function getTakePadArgFromName(padName)
	local raw = tostring(padName or "")
	local exact = raw:match("^(Pad%d+)$")
	if exact then return exact end

	local n = extractPadNumber(raw)
	if n then return "Pad" .. tostring(n) end

	return raw
end

local function getSortedSpinPads()
	local plot = getLocalPlot()
	local spinPads = plot and plot:FindFirstChild("SpinPads")
	if not spinPads then return {}, plot end

	local pads = {}
	for _, pad in ipairs(spinPads:GetChildren()) do
		local pos = getPartPosition(pad)
		if pos then
			table.insert(pads, {Pad = pad, Position = pos, Num = extractPadNumber(pad.Name) or 999})
		end
	end

	table.sort(pads, function(a,b)
		if a.Num ~= b.Num then return a.Num < b.Num end
		return a.Pad.Name < b.Pad.Name
	end)

	local unlocked = getUnlockedPadCount()
	local filtered = {}
	for i, data in ipairs(pads) do
		if unlocked == math.huge or i <= unlocked or data.Num <= unlocked then
			table.insert(filtered, data)
		end
	end

	if #filtered == 0 then return pads, plot end
	return filtered, plot
end

local cachedTextPlot = nil
local cachedTextObjects = {}
local cachedTextObjectSet = {}
local textCacheDirty = true
local lastTextCacheBuild = 0

local function clearTextCache()
	cachedTextObjects = {}
	cachedTextObjectSet = {}
	cachedTextPlot = nil
	textCacheDirty = true
	lastTextCacheBuild = 0
end

local function addCachedTextObject(obj)
	if not obj or not isTextObject(obj) or cachedTextObjectSet[obj] then return end
	cachedTextObjectSet[obj] = true
	table.insert(cachedTextObjects, obj)
end

local function rebuildTextCache(plot)
	cachedTextObjects = {}
	cachedTextObjectSet = {}
	cachedTextPlot = plot
	textCacheDirty = false
	lastTextCacheBuild = os.clock()

	if not plot then return end
	for _, obj in ipairs(plot:GetDescendants()) do
		if isTextObject(obj) then
			addCachedTextObject(obj)
		end
	end
end

local function getAllWorldTexts(plot)
	local texts = {}
	if not plot then return texts end

	local now = os.clock()
	if cachedTextPlot ~= plot or textCacheDirty or (now - lastTextCacheBuild) > TEXT_CACHE_REBUILD_INTERVAL then
		rebuildTextCache(plot)
	end

	for i = #cachedTextObjects, 1, -1 do
		local obj = cachedTextObjects[i]
		if not obj or not obj.Parent then
			cachedTextObjectSet[obj] = nil
			table.remove(cachedTextObjects, i)
		else
			local text = obj.Text
			if text and text ~= "" then
				local pos = getTextObjectWorldPosition(obj)
				if pos then
					local cleaned = cleanText(text)
					table.insert(texts, {
						Object = obj,
						Text = cleaned,
						Lower = cleaned:lower(),
						Position = pos,
						Path = DEBUG and instancePath(obj) or ""
					})
				end
			end
		end
	end

	return texts
end

local function findDirectResultObjectName(pad)
	
	
	local generic = {
		cube = true,
		mouse = true,
		keyboard = true,
		monitor = true,
		pc = true,
		result = true,
		resultobject = true,
		padout = true,
	}

	local containers = {}

	local padOut = pad:FindFirstChild("PadOut", true)
	if padOut then table.insert(containers, padOut) end

	local result = pad:FindFirstChild("Result", true)
	if result then table.insert(containers, result) end

	table.insert(containers, pad)

	for _, root in ipairs(containers) do
		for _, obj in ipairs(root:GetDescendants()) do
			local name = cleanItemName(obj.Name)
			if name and not generic[name:lower()] then
				for itemName in pairs(ITEM_VALUES) do
					if name:lower() == itemName:lower() then
						return itemName
					end
				end
				
				if name:find(" ") then
					return name
				end
			end
		end
	end

	return nil
end

local function scoreTextForPad(textData, padPos)
	local dxz = Vector3.new(textData.Position.X - padPos.X, 0, textData.Position.Z - padPos.Z).Magnitude
	local dy = textData.Position.Y - padPos.Y

	local score = dxz

	
	if parseCashValue(textData.Text) or RARITY_WORDS[textData.Lower] then
		if dxz <= 10 and dy >= -4 and dy <= 16 then
			return score
		end
		return math.huge
	end

	
	if cleanItemName(textData.Text) or parseChance(textData.Text) then
		if dxz <= 16 and dy >= -2 and dy <= 28 then
			return score + math.abs(dy - 8) * 0.12
		end
	end

	return math.huge
end

local function scanOnePad(padData, allTexts)
	local pad = padData.Pad
	local padPos = padData.Position
	local result = {
		Pad = pad,
		PadName = pad.Name,
		PadArg = getTakePadArgFromName(pad.Name),
		PadNum = extractPadNumber(pad.Name) or 0,
		PadPath = instancePath(pad),
		ItemName = nil,
		Rarity = nil,
		Chance = nil,
		Value = nil,
		RawTexts = {},
		Method = "WorldText"
	}

	local nearby = {}
	for _, td in ipairs(allTexts) do
		local s = scoreTextForPad(td, padPos)
		if s < math.huge then
			table.insert(nearby, {Score = s, Data = td})
		end
	end

	table.sort(nearby, function(a,b) return a.Score < b.Score end)

	local bestNameScore = math.huge
	local bestValueScore = math.huge
	local bestRarityScore = math.huge
	local bestChanceScore = math.huge

	for _, entry in ipairs(nearby) do
		local td = entry.Data
		local text = td.Text
		local lower = td.Lower
		table.insert(result.RawTexts, text)

		local val = parseCashValue(text)
		if val and val > 0 and entry.Score < bestValueScore then
			result.Value = val
			bestValueScore = entry.Score
		end

		if RARITY_WORDS[lower] and entry.Score < bestRarityScore then
			result.Rarity = text
			bestRarityScore = entry.Score
		end

		local chance = parseChance(text)
		if chance and entry.Score < bestChanceScore then
			result.Chance = chance
			bestChanceScore = entry.Score
		end

		local nm = cleanItemName(text)
		if nm and entry.Score < bestNameScore then
			result.ItemName = nm
			bestNameScore = entry.Score
		end
	end

	
	if not result.ItemName then
		local objName = findDirectResultObjectName(pad)
		if objName then
			result.ItemName = objName
			result.Method = "ResultObjectFallback"
		end
	end

	
	if (not result.Value or result.Value <= 0) and result.ItemName then
		for k, v in pairs(ITEM_VALUES) do
			if result.ItemName:lower() == k:lower() then
				result.Value = v
				break
			end
		end
	end

	
	
	if result.Value and result.Value > 0 then
		local matchingNames = {}
		for itemName, itemValue in pairs(ITEM_VALUES) do
			if tonumber(itemValue) == tonumber(result.Value) then
				table.insert(matchingNames, itemName)
			end
		end
		if #matchingNames == 1 then
			if not result.ItemName or result.Method == "ResultObjectFallback" then
				result.ItemName = matchingNames[1]
				result.Method = "ValueMap"
			end
		end
	end

	return result
end

local function scanSpinPads()
	local pads, plot = getSortedSpinPads()
	local allTexts = getAllWorldTexts(plot)
	local found = {}

	for _, padData in ipairs(pads) do
		local res = scanOnePad(padData, allTexts)
		if res.ItemName or res.Value or res.Rarity or res.Chance then
			table.insert(found, res)
		else
			table.insert(found, {
				Pad = padData.Pad,
				PadName = padData.Pad.Name,
				PadArg = getTakePadArgFromName(padData.Pad.Name),
				PadNum = extractPadNumber(padData.Pad.Name) or 0,
				PadPath = instancePath(padData.Pad),
				ItemName = "Unknown",
				Rarity = "Unknown",
				Chance = "Unknown",
				Value = 0,
				RawTexts = {},
				Method = "NoText"
			})
		end
	end

	
	table.sort(found, function(a,b)
		local an, bn = a.PadNum or 999, b.PadNum or 999
		if an ~= bn then return an < bn end
		return tostring(a.PadName) < tostring(b.PadName)
	end)

	return found, plot
end

