local function doSpinCycle()
	if busy then return false end
	busy = true

	setState("SPINNING", COLORS.Spinning)

	local spinSuccess, spinResult = pcall(function()
		return SpinRemote:InvokeServer()
	end)

	if not spinSuccess then
		warn("[TinySpinGUI Spin Error]:", spinResult)
		setState("SPIN ERROR", COLORS.Error)
		task.wait(1)
		setState("SPIN", COLORS.Ready)
		busy = false
		return false
	end

	
	scheduleScan("AfterSpin", 0.55, false)

	task.wait(REVEAL_DELAY)

	setState("REVEALING", COLORS.Spinning)

	local revealSuccess, revealResult = pcall(function()
		return RevealRemote:InvokeServer()
	end)

	if not revealSuccess then
		warn("[TinySpinGUI Reveal Error]:", revealResult)
		setState("REVEAL ERR", COLORS.Error)
		task.wait(1)
		setState("SPIN", COLORS.Ready)
		busy = false
		return false
	end

	setState("REVEALED", COLORS.Revealed)
	task.wait(0.35)

	local results = debugDumpSpinPads(false, true)
	local best = findBestResult(results)
	if best then
		lastLabel.Text = "Last: " .. describeResult(best)
	end

	local hit = findThresholdResult(results)
	if hit then
		setState("GOOD ITEM", COLORS.Revealed)
		busy = false
		return true
	end

	task.wait(0.65)
	setState("SPIN", COLORS.Ready)
	busy = false
	return true
end

