local function getListSignature(results, plot)
	local parts = {
		plot and plot.Name or "NoPlot",
		tostring(thresholdLocked),
		formatNumber(lockedThreshold),
		tostring(latestThresholdHit and latestThresholdHit.PadArg or "NoHit")
	}

	for _, r in ipairs(results or {}) do
		table.insert(parts, table.concat({
			tostring(r.PadArg or r.PadName or "?"),
			tostring(r.ItemName or "?"),
			tostring(r.Rarity or "?"),
			tostring(r.Chance or "?"),
			tostring(r.Value or 0),
		}, ":"))
	end

	return table.concat(parts, "|")
end

local function grabPadResult(result)
	if busy then
		warn("[TinySpinGUI Take] Wait until the current spin/reveal finishes.")
		setState("BUSY", COLORS.Error)
		task.delay(0.65, function()
			if not busy then setState("SPIN", COLORS.Ready) end
		end)
		return false
	end

	if not result then
		warn("[TinySpinGUI Take] No pad/result selected.")
		setState("NO PAD", COLORS.Error)
		task.delay(0.8, function() setState("SPIN", COLORS.Ready) end)
		return false
	end

	local padArg = result.PadArg or getTakePadArgFromName(result.PadName)
	if not padArg or padArg == "" then
		warn("[TinySpinGUI Take] Could not resolve Pad# for:", result.PadName)
		setState("PAD ERR", COLORS.Error)
		task.delay(0.8, function() setState("SPIN", COLORS.Ready) end)
		return false
	end

	setState("GRABBING " .. tostring(padArg), COLORS.Spinning)
	print("[TinySpinGUI Take] Taking", padArg, "|", result.ItemName or "Unknown", "|", formatNumber(result.Value or 0))

	
	
	local didNative = tryNativePadActivation(result)
	if didNative and DEBUG then
		print("[TinySpinGUI NativeGrab] Fired native pad interaction for", tostring(padArg))
	end

	
	
	local ok, takeResult = pcall(function()
		return TakeRemote:InvokeServer(padArg)
	end)

	if not ok then
		warn("[TinySpinGUI Take Error]:", takeResult)
		setState("TAKE ERR", COLORS.Error)
		task.delay(1, function() setState("SPIN", COLORS.Ready) end)
		return false
	end

	
	refreshTablesAfterGrab(padArg)

	lastLabel.Text = "Grabbed: " .. describeResult(result)
	setState("GRABBED " .. tostring(padArg), COLORS.Revealed)

	task.delay(1.25, function()
		if scheduleScan then scheduleScan("Take+GetTables", 0.15, true) end
	end)
	task.delay(1.1, function()
		if not busy then setState("SPIN", COLORS.Ready) end
	end)

	return true
end

