local function updatePadList(results, plot, forceRender)
	latestResults = results or {}
	latestPlot = plot
	latestBest = findBestResult(latestResults)
	local thresholdHit = evaluateThreshold(latestResults)

	countLabel.Text = "Pads detected: " .. tostring(#latestResults) .. (plot and (" | " .. plot.Name) or "")

	if latestBest then
		bestLabel.Text = "Best: " .. describeResult(latestBest)
	else
		bestLabel.Text = "Best: None"
	end

	local signature = getListSignature(latestResults, plot)
	if not forceRender and signature == lastListSignature then
		return
	end
	lastListSignature = signature

	clearList()

	if #latestResults == 0 then
		addListLine("No pads detected. Check Workspace > Main > Plots > Plot# > SpinPads", 1, COLORS.SubText)
		return
	end

	for i, r in ipairs(latestResults) do
		local rowColor = COLORS.SubText
		if thresholdHit and r.PadArg == thresholdHit.PadArg then
			rowColor = COLORS.YellowText
		elseif latestBest and r.PadArg == latestBest.PadArg then
			rowColor = COLORS.GreenText
		end
		addPadRow(r, i, rowColor)
	end
end

