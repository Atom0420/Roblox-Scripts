local function findBestResult(results)
	local best = nil
	for _, r in ipairs(results or {}) do
		if not best then
			best = r
		else
			local rv = tonumber(r.Value) or 0
			local bv = tonumber(best.Value) or 0
			if rv > bv then
				best = r
			elseif rv == bv and (r.PadNum or 999) < (best.PadNum or 999) then
				best = r
			end
		end
	end
	return best
end

local function findThresholdResult(results)
	if not thresholdLocked or lockedThreshold == math.huge then return nil end

	local bestHit = nil
	for _, r in ipairs(results or {}) do
		local value = tonumber(r.Value) or 0
		if value >= lockedThreshold then
			if not bestHit then
				bestHit = r
			else
				local hitValue = tonumber(bestHit.Value) or 0
				if value > hitValue then
					bestHit = r
				elseif value == hitValue and (r.PadNum or 999) < (bestHit.PadNum or 999) then
					bestHit = r
				end
			end
		end
	end
	return bestHit
end

local function describeResult(r)
	if not r then return "None" end
	return tostring(r.PadArg or r.PadName or "Pad?") .. " - " .. tostring(r.ItemName or "Unknown") .. " / $" .. formatNumber(r.Value or 0)
end

local function evaluateThreshold(results)
	local hit = findThresholdResult(results)
	latestThresholdHit = hit

	if hit then
		local key = tostring(hit.PadArg) .. ":" .. tostring(hit.ItemName) .. ":" .. tostring(hit.Value)
		searchLabel.Text = "FOUND >= $" .. formatNumber(lockedThreshold) .. ": " .. describeResult(hit)

		if key ~= lastThresholdKey then
			lastThresholdKey = key
			print("[TinySpinGUI Threshold Hit]", describeResult(hit))
		end

		if autoSpin then
			autoSpin = false
			autoButton.Text = "AUTO: OFF"
			autoButton.BackgroundColor3 = COLORS.Idle
			print("[TinySpinGUI Auto Stop] Threshold hit. Use GRAB BEST or the pad's GRAB button.")
		end

		if not busy then
			setState("GOOD ITEM", COLORS.Revealed)
		end
	else
		lastThresholdKey = nil
		updateSearchLabel()
	end

	return hit
end

