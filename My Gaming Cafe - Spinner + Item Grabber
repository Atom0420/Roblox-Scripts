local function safeFireProximityPrompt(prompt)
	if typeof(fireproximityprompt) == "function" then
		local ok = pcall(function()
			fireproximityprompt(prompt)
		end)
		return ok
	end
	return false
end

local function safeFireClickDetector(clickDetector)
	if typeof(fireclickdetector) == "function" then
		local ok = pcall(function()
			fireclickdetector(clickDetector)
		end)
		return ok
	end
	return false
end

local function safeTouchPart(part)
	if typeof(firetouchinterest) ~= "function" then return false end
	local root = getCharacterRootPart()
	if not root or not part or not part:IsA("BasePart") then return false end

	local ok = pcall(function()
		firetouchinterest(root, part, 0)
		task.wait(0.03)
		firetouchinterest(root, part, 1)
	end)
	return ok
end

local function tryNativePadActivation(result)
	
	
	local pad = result and result.Pad
	if not pad then return false end

	local didNative = false

	for _, obj in ipairs(pad:GetDescendants()) do
		if obj:IsA("ProximityPrompt") then
			didNative = safeFireProximityPrompt(obj) or didNative
		end
	end

	for _, obj in ipairs(pad:GetDescendants()) do
		if obj:IsA("ClickDetector") then
			didNative = safeFireClickDetector(obj) or didNative
		end
	end

	
	
	local touched = 0
	for _, obj in ipairs(pad:GetDescendants()) do
		if touched >= 4 then break end
		if obj:IsA("BasePart") then
			local n = obj.Name:lower()
			if n:find("pad", 1, true) or n:find("out", 1, true) or n:find("button", 1, true) or n:find("touch", 1, true) then
				if safeTouchPart(obj) then
					didNative = true
					touched += 1
				end
			end
		end
	end

	return didNative
end

